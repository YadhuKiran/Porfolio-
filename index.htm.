<!DOCTYPE html>
<html lang="en">
  <head>
    <!--
      Personal Portfolio Website (HTML + CSS only)
      Owner: Yadhu Kiran V T
      Note: Replace `profile.jpg` and project images with your own files later.
    -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Portfolio of Yadhu Kiran V T - Information Science & Engineering Student | IoT & Software Enthusiast"
    />

    <title>Yadhu Kiran V T | Portfolio</title>

    <!-- Google Font (Poppins) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Your stylesheet -->
    <link rel="stylesheet" href="style.css" />
  </head>

  <body>
    <!-- =========================
         Fixed Navigation Bar
         ========================= -->
    <header class="site-header">
      <nav class="nav container" aria-label="Primary navigation">
        <!-- Logo / Name -->
        <a class="nav__brand" href="#home">Yadhu Kiran</a>

        <!-- Navigation Links -->
        <ul class="nav__links">
          <li><a class="nav__link" href="#home">Home</a></li>
          <li><a class="nav__link" href="#about">About</a></li>
          <li><a class="nav__link" href="#projects">Projects</a></li>
          <li><a class="nav__link" href="#contact">Contact</a></li>
        </ul>
      </nav>
    </header>

    <!-- Main content -->
    <main>
      <!-- =========================
           Home / Hero Section
           (Flexbox layout)
           ========================= -->
      <section id="home" class="section hero">
        <div class="container hero__content">
          <!-- Profile image (replace profile.jpg with your own photo later) -->
          <figure class="hero__figure">
            <img
              class="hero__image"
              src="profile.jpg"
              alt="Profile photo of Yadhu Kiran V T"
              loading="lazy"
            />
          </figure>

          <!-- Personal details -->
          <div class="hero__text">
            <p class="hero__eyebrow">Hello, I’m</p>
            <h1 class="hero__name">Yadhu Kiran V T</h1>
            <p class="hero__title">Information Science Engineering Student</p>

            <p class="hero__description">
              I am an Information Science student passionate about IoT systems,
              Raspberry Pi projects, and modern web technologies. I enjoy building
              systems that combine hardware and software to solve real-world
              problems.
            </p>

            <!-- Button scrolls to the Contact section -->
            <a class="btn" href="#contact">Contact Me</a>

            <!-- Optional: quick links (pure HTML anchor links) -->
            <div class="hero__social" aria-label="Social links">
              <a
                class="link"
                href="https://www.linkedin.com/in/yadhu-kiranvt/"
                target="_blank"
                rel="noreferrer"
                >LinkedIn</a
              >
              <a
                class="link"
                href="https://github.com/YadhuKiran"
                target="_blank"
                rel="noreferrer"
                >GitHub</a
              >
              <a
                class="link"
                href="https://www.instagram.com/yadhu_kiran_/"
                target="_blank"
                rel="noreferrer"
                >Instagram</a
              >
            </div>
          </div>
        </div>
      </section>

      <!-- =========================
           About Section
           ========================= -->
      <section id="about" class="section section--alt">
        <div class="container">
          <header class="section__header">
            <h2 class="section__title">About Me</h2>
            <p class="section__subtitle">
              Information Science &amp; Engineering Student | IoT &amp; Software
              Enthusiast
            </p>
          </header>

          <div class="prose">
            <p>
              I am currently pursuing my B.Tech in Information Science and
              Engineering. I have experience working with IoT devices such as
              Raspberry Pi and Arduino, building real-time monitoring systems,
              and developing web applications.
            </p>
            <p>
              I have worked on several projects including an underwater current
              speed sensor system using Raspberry Pi and an IoT-based home
              automation system using Arduino. I am also interested in software
              development and web technologies.
            </p>
          </div>
        </div>
      </section>

      <!-- =========================
           Projects Section
           (CSS Grid layout)
           ========================= -->
      <section id="projects" class="section">
        <div class="container">
          <header class="section__header">
            <h2 class="section__title">My Projects</h2>
            <p class="section__subtitle">
              A few projects showcasing my IoT and software interests.
            </p>
          </header>

          <!-- Project cards grid -->
          <div class="projects-grid">
            <!-- Project 1 -->
            <article class="card">
              <!-- Placeholder image: replace with your own (example: project1.jpg) -->
              <img
                class="card__image"
                src="https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1200&q=80"
                alt="Circuit board close-up representing electronics and IoT"
                loading="lazy"
              />
              <div class="card__body">
                <h3 class="card__title">Low Power Underwater Current Speed Sensor</h3>
                <p class="card__text">
                  A Raspberry Pi based system designed to monitor underwater
                  current speeds in real time. The project was developed for
                  public health safety and helps fishermen detect dangerous
                  underwater currents.
                </p>
                <a class="btn btn--secondary" href="#contact">View Project</a>
              </div>
            </article>

            <!-- Project 2 -->
            <article class="card">
              <img
                class="card__image"
                src="https://images.unsplash.com/photo-1558002038-1055907df827?auto=format&fit=crop&w=1200&q=80"
                alt="Smart home devices and lighting representing automation"
                loading="lazy"
              />
              <div class="card__body">
                <h3 class="card__title">IoT Based Home Automation System</h3>
                <p class="card__text">
                  An Arduino based smart home automation system that allows
                  users to control lights and appliances through sensors and
                  automation.
                </p>
                <a class="btn btn--secondary" href="#contact">View Project</a>
              </div>
            </article>

            <!-- Project 3 -->
            <article class="card">
              <img
                class="card__image"
                src="https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?auto=format&fit=crop&w=1200&q=80"
                alt="Buddhist monastery architecture representing Sikkim monasteries"
                loading="lazy"
              />
              <div class="card__body">
                <h3 class="card__title">Sikkim Monastery Information Platform</h3>
                <p class="card__text">
                  A web-based platform that showcases famous Buddhist monasteries
                  in Sikkim. The website allows users to explore monasteries,
                  learn about their history, cultural significance, and important
                  tourist information through a clean and interactive interface.
                </p>
                <a
                  class="btn btn--secondary"
                  href="https://v0-sikkim-monastery-platform-gray.vercel.app/"
                  target="_blank"
                  rel="noreferrer"
                  >View Project</a
                >
              </div>
            </article>
          </div>
        </div>
      </section>

      <!-- =========================
           Contact Section
           (Centered form using Flexbox)
           ========================= -->
      <section id="contact" class="section section--alt">
        <div class="container">
          <header class="section__header">
            <h2 class="section__title">Contact Me</h2>
            <p class="section__subtitle">
              Let’s connect! Send a message or reach me through the links below.
            </p>
          </header>

          <!-- Contact info (simple and readable) -->
          <div class="contact-meta">
            <p><strong>Phone:</strong> +91 9731046170</p>
            <p>
              <strong>LinkedIn:</strong>
              <a
                class="link"
                href="https://www.linkedin.com/in/yadhu-kiranvt/"
                target="_blank"
                rel="noreferrer"
                >yadhu-kiranvt</a
              >
            </p>
            <p>
              <strong>GitHub:</strong>
              <a
                class="link"
                href="https://github.com/YadhuKiran"
                target="_blank"
                rel="noreferrer"
                >YadhuKiran</a
              >
            </p>
            <p>
              <strong>Instagram:</strong>
              <a
                class="link"
                href="https://www.instagram.com/yadhu_kiran_/"
                target="_blank"
                rel="noreferrer"
                >@yadhu_kiran_</a
              >
            </p>
          </div>

          <!-- Centered contact form -->
          <div class="contact">
            <!--
              This form uses only HTML. Without JavaScript or a backend,
              the form won't actually send messages.
              Later, you can connect it to a service (Formspree, Netlify Forms, etc.)
              or your own backend.
            -->
            <form class="form" action="#" method="post">
              <div class="form__row">
                <label class="form__label" for="name">Name</label>
                <input
                  class="form__input"
                  type="text"
                  id="name"
                  name="name"
                  placeholder="Your full name"
                  required
                />
              </div>

              <div class="form__row">
                <label class="form__label" for="email">Email</label>
                <input
                  class="form__input"
                  type="email"
                  id="email"
                  name="email"
                  placeholder="you@example.com"
                  required
                />
              </div>

              <div class="form__row">
                <label class="form__label" for="message">Message</label>
                <textarea
                  class="form__input form__textarea"
                  id="message"
                  name="message"
                  placeholder="Write your message..."
                  rows="5"
                  required
                ></textarea>
              </div>

              <button class="btn" type="submit">Submit</button>
            </form>
          </div>
        </div>
      </section>
    </main>

    <!-- =========================
         Footer
         ========================= -->
    <footer class="footer">
      <div class="container footer__content">
        <p>© 2026 Yadhu Kiran V T</p>
        <p>All Rights Reserved</p>
      </div>
    </footer>
  </body>
</html>
